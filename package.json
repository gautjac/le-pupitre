{
  "name": "le-pupitre",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "netlify dev",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "emit:sample": "tsx scripts/emit-sample.ts",
    "verify:python": "tsx scripts/emit-sample.ts /tmp/le-pupitre-out > /dev/null && python3 -m py_compile /tmp/le-pupitre-out/*/*.py && echo 'python ok'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "jszip": "^3.10.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@netlify/functions": "^5.2.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^2.1.8"
  }
}
